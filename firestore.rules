rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'noorullahsail0@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    match /test/connection {
      allow read: if true;
    }

    // Student Validation
    function isValidStudent(data) {
      return data.regNo is string && data.regNo.size() <= 100
        && data.name is string && data.name.size() <= 200
        && data.fatherName is string && data.fatherName.size() <= 200
        && data.phone is string && data.phone.size() <= 50
        && data.section in ['بنین درس نظامی', 'بنات درس نظامی', 'بنین درجہ حفظ']
        && data.currentClass is string && data.currentClass.size() <= 150;
    }

    match /students/{studentId} {
      allow read, list: if isSignedIn();
      allow create: if isAdmin() && isValidId(studentId) && isValidStudent(incoming());
      allow update: if isAdmin() && isValidStudent(incoming()) 
                     && incoming().regNo == existing().regNo;
      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read, list: if isSignedIn();
      allow create: if isAdmin() && isValidId(attendanceId)
        && incoming().status in ['present', 'absent', 'leave']
        && incoming().date is string;
      allow update: if isAdmin() && incoming().status in ['present', 'absent', 'leave'];
      allow delete: if isAdmin();
    }

    match /results/{resultId} {
      allow read, list: if isSignedIn();
      allow create: if isAdmin() && isValidId(resultId)
        && incoming().examType in ['امتحان سہ ماہی', 'امتحان شش ماہی', 'امتحان سالانہ']
        && incoming().year is string;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
