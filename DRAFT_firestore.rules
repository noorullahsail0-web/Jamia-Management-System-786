rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net default catch-all denial
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    // Enforce email equivalence + strict verification factor to prevent spoofing
    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.email_verified == true &&
        request.auth.token.email == 'noorullahsail0@gmail.com';
    }

    // Path Variable & ID Poisoning Guard
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Public/anyone connection diagnostic check
    match /test/connection {
      allow read: if true;
    }

    // Student Validation Blueprint (The "Anti-Update-Gap")
    function isValidStudent(data) {
      return data.regNo is string && data.regNo.size() <= 100
        && data.name is string && data.name.size() <= 200
        && data.fatherName is string && data.fatherName.size() <= 200
        && data.phone is string && data.phone.size() <= 50
        && data.section in ['بنین درس نظامی', 'بنات درس نظامی', 'بنین درجہ حفظ']
        && data.currentClass is string && data.currentClass.size() <= 150
        && (!('dob' in data) || (data.dob is string && data.dob.size() <= 50))
        && (!('cnic' in data) || (data.cnic is string && data.cnic.size() <= 50))
        && (!('address' in data) || (data.address is string && data.address.size() <= 1000))
        && (!('photoUrl' in data) || (data.photoUrl is string && data.photoUrl.size() <= 2000))
        && (!('status' in data) || (data.status in ['active', 'left', 'graduated']))
        && (!('isResident' in data) || (data.isResident is bool))
        && (!('admissionDate' in data) || (data.admissionDate is string && data.admissionDate.size() <= 50))
        && (!('leavingDate' in data) || (data.leavingDate is string && data.leavingDate.size() <= 50))
        && (!('leavingReason' in data) || (data.leavingReason is string && data.leavingReason.size() <= 500))
        && (!('leavingClass' in data) || (data.leavingClass is string && data.leavingClass.size() <= 150))
        && (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 100))
        && (!('updatedAt' in data) || (data.updatedAt is string && data.updatedAt.size() <= 100));
    }

    match /students/{studentId} {
      allow get: if isAdmin() && isValidId(studentId);
      allow list: if isAdmin();
      allow create: if isAdmin() && isValidId(studentId) && isValidStudent(incoming());
      allow update: if isAdmin() && isValidId(studentId) && isValidStudent(incoming()) && (
        (!('createdAt' in existing()) || incoming().createdAt == existing().createdAt)
      );
      allow delete: if isAdmin() && isValidId(studentId);
    }

    // Attendance Validation Blueprint
    function isValidAttendance(data) {
      return data.studentId is string && data.studentId.size() <= 128
        && data.date is string && data.date.size() <= 50
        && data.status in ['present', 'absent', 'leave']
        && (!('section' in data) || (data.section is string && data.section.size() <= 150))
        && (!('class' in data) || (data.class is string && data.class.size() <= 150))
        && (!('createdAt' in data) || data.createdAt == request.time);
    }

    match /attendance/{attendanceId} {
      allow get: if isAdmin() && isValidId(attendanceId);
      allow list: if isAdmin();
      allow create: if isAdmin() && isValidId(attendanceId) && isValidAttendance(incoming())
        && exists(/databases/$(database)/documents/students/$(incoming().studentId));
      allow update: if isAdmin() && isValidId(attendanceId) && isValidAttendance(incoming());
      allow delete: if isAdmin() && isValidId(attendanceId);
    }

    // ExamResult Validation Blueprint
    function isValidExamResult(data) {
      return data.studentId is string && data.studentId.size() <= 128
        && data.examType in ['امتحان سہ ماہی', 'امتحان شش ماہی', 'امتحان سالانہ', 'سہ ماہی', 'شش ماہی', 'سالانہ']
        && data.year is string && data.year.size() <= 10
        && (!('class' in data) || (data.class is string && data.class.size() <= 150))
        && (!('subjects' in data) || data.subjects is map)
        && (!('hifzBreakdown' in data) || (data.hifzBreakdown == null || data.hifzBreakdown is map))
        && (!('totalMarks' in data) || data.totalMarks is number)
        && (!('percentage' in data) || data.percentage is number)
        && (!('grade' in data) || (data.grade is string && data.grade.size() <= 50))
        && (!('updatedAt' in data) || data.updatedAt == request.time);
    }

    match /results/{resultId} {
      allow get: if isAdmin() && isValidId(resultId);
      allow list: if isAdmin();
      allow create: if isAdmin() && isValidId(resultId) && isValidExamResult(incoming())
        && exists(/databases/$(database)/documents/students/$(incoming().studentId));
      allow update: if isAdmin() && isValidId(resultId) && isValidExamResult(incoming());
      allow delete: if isAdmin() && isValidId(resultId);
    }
  }
}
